# ─────────────────────────────────────────────────────────────────────────────
# SureFlow OS — backend configuration
#
# Copy this file to `.env` and fill in your values:
#     cp backend/.env.example backend/.env
#
# Every key here has a default in `core/config.py`, so the only value you
# genuinely must set is GEMINI_API_KEY.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Google AI Studio → https://aistudio.google.com/apikey  (free tier is enough)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres + pgvector. Use the local Docker instance:
DATABASE_URL=postgresql://sureflow_user:sureflow_password@localhost:5433/sureflow_db
# ...or point at a hosted Neon database instead.

# ── Neo4j (Industrial Knowledge Graph) ───────────────────────────────────────
# Use `bolt://neo4j:7687` when the backend runs inside Docker Compose;
# docker-compose.yml already overrides this for you.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sureflow_password

# ── Ollama (embeddings + offline LLM fallback) ───────────────────────────────
# `nomic-embed-text` for embeddings, `llama3.2` as the fallback model.
OLLAMA_BASE_URL=http://localhost:11434

# ── Auth ─────────────────────────────────────────────────────────────────────
# Change this to any random string before deploying anywhere real.
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# ── Frontend / CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=True

# ── OCR toolchain (Windows only) ─────────────────────────────────────────────
# Leave unset on macOS/Linux and inside Docker — the binaries are on PATH there.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\poppler\Library\bin
